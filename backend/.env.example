# Create backend/.env locally and put your real key there. Never commit it.
# Optional live Qwen profile using an OpenAI-compatible endpoint.
QWEN_API_KEY=
QWEN_PROVIDER=bailian-cn
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-flash

# Durable lesson, trace, and interaction storage. A relative path is suitable
# for local use; a managed deployment can point this at a mounted volume.
AXISLAB_DB_PATH=data/axislab.db

# Optional international Qwen profile.
# QWEN_PROVIDER=qwen-cloud
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3.7-plus
